# Bybit Futures API
BYBIT_API_KEY=your_api_key_here
BYBIT_SECRET=your_secret_key_here

# Webhook защита (любая случайная строка, ту же укажи в TradingView alert message)
WEBHOOK_SECRET=my_secret_token_123

# Режим торговли: true = реальные деньги, false = paper trading (testnet)
LIVE_TRADING=false

# Размер позиции (% от баланса на сделку)
POSITION_SIZE_PCT=10

# Кредитное плечо
LEVERAGE=5

# Максимум одновременных позиций
MAX_POSITIONS=2

# Порт сервера
PORT=3000
